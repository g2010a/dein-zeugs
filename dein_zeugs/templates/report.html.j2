{% macro transcript_block(t) %}{% if t %}<details class="transcript-details">
  <summary>Transkript</summary>
  <div class="transcript-body">{{ t[:300] }}{% if t|length > 300 %}<span class="transcript-ellipsis">&hellip;</span><span class="transcript-rest" hidden>{{ t[300:] }}</span><div><button class="transcript-expand-btn" type="button">Mehr anzeigen</button></div>{% endif %}</div>
</details>{% endif %}{% endmacro %}
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dein Zeugs Report</title>
  <style>{{ css | safe }}</style>
</head>
<body>
  <nav class="sticky-nav">
    <a href="#all-questions">Alle Fragen (<span id="nav-all-count">{{ (processed|length) + (aired|length) }}</span>)</a>
    <a href="#clusters">Cluster ({{ named_clusters|length }})</a>
  </nav>

  <div class="filter-bar">
    <input type="search" id="q" placeholder="&#x1F50D; Suchen&#x2026; (Taste /)" autocomplete="off">
    <div class="filter-chips">
      <button class="filter-btn" data-filter="new">Neu</button>
      <button class="filter-btn" data-filter="aired">Ausgestrahlt</button>
      <button class="filter-btn" id="toggle-keyword-cloud" style="display:none">Schlagw&#246;rter &#x25BE;</button>
      <button class="filter-btn" id="btn-group-by-cluster">Nach Cluster gruppieren</button>
    </div>
  </div>
  <div id="keyword-cloud" class="keyword-cloud" style="display:none"></div>

  <main>
    <div class="banner">
      {{ aired_count }} von {{ total_questions_count }} Fragen wurden bereits ausgestrahlt.
      <a class="banner-link" href="file://{{ inbox_path }}/">Inbox &#246;ffnen</a>
      <a class="banner-link" href="file://{{ aired_path }}/">Aired &#246;ffnen</a>
    </div>
    {% if llm_error_count %}
    <div class="banner banner-error">
      &#x26A0;&#xFE0F; KI-Analyse fehlgeschlagen f&#252;r {{ llm_error_count }} Frage{% if llm_error_count != 1 %}n{% endif %} &mdash; Zusammenfassung und Schlagw&#246;rter nicht verf&#252;gbar. Die Transkripte sind vollst&#228;ndig.
    </div>
    {% endif %}

    <div class="transcript-toolbar">
      <span>Transkripte:</span>
      <button id="toggle-all-transcripts" type="button">Alle aufklappen</button>
    </div>

    {# ── Unified question list ── #}
    <section id="all-questions">
      <div class="section-header">
        <h2>Alle Fragen <span class="live-count" id="all-questions-count"></span></h2>
      </div>
      {% if processed or aired %}
      <table id="all-questions-table">
        <thead>
          <tr>
            <th data-sort="stem">Stem <span class="sort-icon"></span></th>
            <th>Zusammenfassung</th>
            <th>Transkript</th>
            <th>Schlagw&#246;rter</th>
            <th data-sort="similarity">&#196;hnlichkeit <span class="sort-icon"></span></th>
            <th data-sort="novelty" class="sort-active sort-desc">Neuheitswert <span class="sort-icon">&#x25BC;</span></th>
            <th data-sort="first-seen">Erstmals gesehen <span class="sort-icon"></span></th>
            <th data-sort="analyzed-at">Zuletzt verarbeitet <span class="sort-icon"></span></th>
            <th>Audio</th>
          </tr>
        </thead>
        <tbody id="all-questions-tbody">
          {% for item in processed %}
          <tr{% if item.similarity_score >= threshold %} class="repeat"{% endif %}
              data-stem="{{ item.stem }}"
              data-summary="{{ item.summary }}"
              data-keywords="{{ item.keywords | join(',') | lower }}"
              data-similarity="{{ item.similarity_score }}"
              data-novelty="{{ item.novelty_score }}"
              data-first-seen="{{ item.first_seen }}"
              data-analyzed-at="{{ item.analyzed_at }}"
              data-section="processed"
              {% if item.cluster_id %}data-cluster="{{ item.cluster_id }}"{% endif %}
              {% if item.llm_error %}data-error="1"{% endif %}>
            <td class="stem">{{ item.stem }}</td>
            <td>{{ item.summary }}</td>
            <td>{{ transcript_block(item.transcript) }}</td>
            <td>{% for kw in item.keywords %}<span class="chip chip-kw" data-kw="{{ kw | lower }}">{{ kw }}</span> {% endfor %}</td>
            <td>{{ "%.2f"|format(item.similarity_score) }}</td>
            <td>
              <div class="novelty-cell">
                <div class="bar-mini"><div class="bar-fill {% if item.novelty_score >= 0.7 %}bar-green{% elif item.novelty_score >= 0.4 %}bar-amber{% else %}bar-red{% endif %}" style="width:{{ (item.novelty_score * 100)|round|int }}%"></div></div>
                {{ "%.2f"|format(item.novelty_score) }}
              </div>
            </td>
            <td class="date-cell">{{ item.first_seen[:10] if item.first_seen else "&#x2014;" }}</td>
            <td class="date-cell">{{ item.analyzed_at[:10] if item.analyzed_at else "&#x2014;" }}</td>
            <td><a class="audio-link" href="file://{{ inbox_path }}/{{ item.stem }}.mp3" target="_blank">&#x25B6;</a></td>
          </tr>
          {% endfor %}
          {% for item in aired %}
          <tr class="row-aired{% if item.similarity_score >= threshold %} repeat{% endif %}"
              data-stem="{{ item.stem }}"
              data-summary="{{ item.summary }}"
              data-keywords="{{ item.keywords | join(',') | lower }}"
              data-similarity="{{ item.similarity_score }}"
              data-novelty="{{ item.novelty_score }}"
              data-first-seen="{{ item.first_seen }}"
              data-analyzed-at="{{ item.analyzed_at }}"
              data-section="aired"
              {% if item.cluster_id %}data-cluster="{{ item.cluster_id }}"{% endif %}
              {% if item.llm_error %}data-error="1"{% endif %}>
            <td class="stem">
              <span class="chip chip-aired" title="Ausgestrahlt">&#x1F4E1;</span>
              {{ item.stem }}
            </td>
            <td>{{ item.summary }}</td>
            <td>{{ transcript_block(item.transcript) }}</td>
            <td>{% for kw in item.keywords %}<span class="chip chip-kw" data-kw="{{ kw | lower }}">{{ kw }}</span> {% endfor %}</td>
            <td>{{ "%.2f"|format(item.similarity_score) }}</td>
            <td>
              <div class="novelty-cell">
                <div class="bar-mini"><div class="bar-fill bar-gray" style="width:{{ (item.novelty_score * 100)|round|int }}%"></div></div>
                {{ "%.2f"|format(item.novelty_score) }}
              </div>
            </td>
            <td class="date-cell">{{ item.first_seen[:10] if item.first_seen else "&#x2014;" }}</td>
            <td class="date-cell">{{ item.analyzed_at[:10] if item.analyzed_at else "&#x2014;" }}</td>
            <td><a class="audio-link" href="file://{{ aired_path }}/{{ item.stem }}.mp3" target="_blank">&#x25B6;</a></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      <div class="table-footer">
        <div class="pagination" id="pagination-controls"></div>
        <div class="table-page-size">
          Zeilen:
          <select id="page-size">
            <option value="25">25</option>
            <option value="50">50</option>
            <option value="100">100</option>
            <option value="0">Alle</option>
          </select>
        </div>
      </div>
      <p class="note">Amber markierte Zeilen haben eine &#196;hnlichkeit &ge; {{ "%.2f"|format(threshold) }} und k&#246;nnten Wiederholungen sein.</p>
      {% else %}
      <p class="empty">Keine Fragen gefunden.</p>
      {% endif %}
    </section>

    {# ── Cluster section ── #}
    <section id="clusters">
      <div class="section-header">
        <h2>&#196;hnlichkeits-Cluster</h2>
      </div>
      {% if named_clusters %}
      <p class="note" style="padding:0.6rem 1.25rem; border-top:none;">Schwellenwert: {{ "%.2f"|format(threshold) }}. Gruppen inhaltlich &#228;hnlicher Fragen.</p>

      {% set new_named = named_clusters | rejectattr("is_mixed") | list %}
      {% set mixed_named = named_clusters | selectattr("is_mixed") | list %}

      {% if new_named %}
      <div class="cluster-type-group cluster-group-new">
        <h3 class="cluster-type-heading">Neue Cluster <span class="chip">nur neue Fragen</span></h3>
        {% for cluster in new_named %}
        <div class="cluster-card" data-cluster-id="{{ cluster.id }}">
          <div class="cluster-name-row">
            <span class="cluster-name-label">{{ cluster.name }}</span>
            <span class="chip">{{ cluster.stems|length }} Fragen</span>
          </div>
          <ul class="cluster-stems">
            {% for stem in cluster.stems %}
            <li>{{ stem }}</li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
      {% endif %}

      {% if mixed_named %}
      <div class="cluster-type-group cluster-group-mixed">
        <h3 class="cluster-type-heading">Gemischte Cluster <span class="chip">neue + ausgestrahlte Fragen</span></h3>
        {% for cluster in mixed_named %}
        <div class="cluster-card" data-cluster-id="{{ cluster.id }}">
          <div class="cluster-name-row">
            <span class="cluster-name-label">{{ cluster.name }}</span>
            <span class="chip">{{ cluster.stems|length }} Fragen</span>
          </div>
          <ul class="cluster-stems">
            {% for stem in cluster.stems %}
            <li>
              {{ stem }}
              {% if stem in aired_stems %}<span class="chip chip-aired" title="Ausgestrahlt">&#x1F4E1;</span>{% endif %}
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
      {% endif %}

      {% else %}
      <p class="empty">Keine Cluster &#x2014; nicht genug verarbeitete Fragen mit Einbettungen.</p>
      {% endif %}
    </section>

  </main>

  <script>var CLUSTER_NAMES = {{ cluster_names_json | safe }};</script>
  <script>{{ js | safe }}</script>
</body>
</html>
